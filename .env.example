# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stock_agent

# Redis (for Celery)
REDIS_URL=redis://localhost:6379/0

# Finnhub API (optional — mock data used if not provided)
FINNHUB_API_KEY=

# App settings
APP_ENV=development
LOG_LEVEL=INFO

# Ingestion schedule (cron expression, default: every hour)
INGEST_CRON_SCHEDULE=0 * * * *
